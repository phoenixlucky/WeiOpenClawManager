{
  "name": "openclaw-manager",
  "version": "1.1.1",
  "description": "Local web client for managing OpenClaw version info and .openclaw config",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "start:web": "node server.js",
    "build:win": "electron-builder --win nsis -c.electronDist=node_modules/electron/dist",
    "build:installer": "electron-builder --win nsis -c.electronDist=node_modules/electron/dist"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.openclaw.manager",
    "productName": "OpenClawManager",
    "directories": {
      "output": "dist/electron",
      "buildResources": "build"
    },
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "server.js",
      "public/**/*",
      "build/icon.png",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "OpenClaw-Manager-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenClawManager",
      "installerIcon": "build/installerIcon.ico",
      "uninstallerIcon": "build/uninstallerIcon.ico",
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "artifactName": "OpenClaw-Manager-Setup-${version}.${ext}"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
